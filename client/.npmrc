# Tolerate peer-dep warnings — SDK 54 + RN 0.81 has several libs that
# still advertise older peer ranges. Without this `npm ci` on EAS can
# abort with ERESOLVE.
legacy-peer-deps=true

# EAS build workers occasionally drop TCP connections mid-download for
# large native modules (react-native-webrtc is ~80MB, FBSDK is chunky).
# Default npm retries (2 attempts, 1s gap) give up too quickly and you
# get ECONNRESET. Ramp these up so a blip doesn't kill the whole build.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
