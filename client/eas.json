{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_NO_DEV_CLIENT": "1",
        "EXPO_PUBLIC_FACEBOOK_APP_ID": "1154080012747807",
        "EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN": "c99709deda6f1100bc89ae45c3bba7df"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_NO_DEV_CLIENT": "1",
        "EXPO_PUBLIC_FACEBOOK_APP_ID": "1154080012747807",
        "EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN": "c99709deda6f1100bc89ae45c3bba7df"
      }
    },
    "production": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "applicationArchivePath": "android/app/build/outputs/apk/release/*.apk"
      },
      "env": {
        "EXPO_NO_DEV_CLIENT": "1",
        "EXPO_PUBLIC_FACEBOOK_APP_ID": "1154080012747807",
        "EXPO_PUBLIC_FACEBOOK_CLIENT_TOKEN": "c99709deda6f1100bc89ae45c3bba7df"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
