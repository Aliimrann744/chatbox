# Database Configuration
DATABASE_URL="mysql://username:password@localhost:3306/database_name"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Frontend URL (for OAuth callbacks and email links)
FRONTEND_URL="http://localhost:3000"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/v1/auth/google/callback"

# Facebook OAuth Configuration
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_CALLBACK_URL="http://localhost:4000/v1/auth/facebook/callback"

# LinkedIn OAuth Configuration
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
LINKEDIN_CALLBACK_URL="http://localhost:4000/v1/auth/linkedin/callback"

# Email/SMTP Configuration (for Password Reset)
# For Gmail, you need to create an "App Password" after enabling 2-factor authentication
# Go to: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
SMTP_FROM_NAME="Your App Name"
SMTP_FROM_EMAIL="your-email@gmail.com"
INVITATION_EXPIRY_HOURS=24

# Cloudinary Configuration (if using image uploads)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Server Configuration
# IMPORTANT: Backend runs on port 4000, Frontend runs on port 3000
PORT=4000
NODE_ENV="development"

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-api-key-here"

# ElevenLabs Configuration (for voice AI agent)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_AGENT_ID="your-agent-id"

# Twilio WhatsApp Configuration
# Get credentials from: https://console.twilio.com
# IMPORTANT: For sandbox/testing, use +14155238886 (Twilio's sandbox number)
# For production, use your approved WhatsApp Business number
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_NUMBER="+14155238886"

# Authentication
AUTH_KEY="your-auth-key-for-api-security"
